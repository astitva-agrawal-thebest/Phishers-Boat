{
  "manifest_version": 3,
  "name": "AI Phishing Defense",
  "version": "1.0",
  "description": "Real-time local scanner that inspects emails, URLs, and QR codes.",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost/*",
    "https://your-backend-domain.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/scanner.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content/injector.css"],
      "js": ["content/injector.js"],
      "run_at": "document_idle"
    }
  ]
}
